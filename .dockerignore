go.work
go.work.sum

# node_modules trees: the docker portal stage runs its own `npm ci` and
# would otherwise be clobbered by `COPY portal/ portal/` from the local
# checkout. Provider portal `node_modules` are symlinks that dangle once
# they leave the workspace tree — strip them too; the portal stage
# recreates them.
portal/node_modules
providers/*/portal/node_modules

# Local Vite build outputs: regenerated by the portal stage. Excluding
# them from the build context shaves a few MB and avoids leaking stale
# bundles in case `COPY .` runs before the dist overwrite.
portal/dist
providers/*/portal/dist
