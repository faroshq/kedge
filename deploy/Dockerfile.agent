FROM --platform=$BUILDPLATFORM golang:1.26 AS builder

ARG TARGETARCH
ARG TARGETOS=linux

WORKDIR /workspace
COPY go.mod go.sum ./
# The provider-sdk is a monorepo submodule pulled in via a local
# `replace => ./provider-sdk`; go mod download reads its go.mod to resolve
# the replacement, so it must be present before the download step.
COPY provider-sdk/go.mod provider-sdk/go.sum provider-sdk/
RUN go mod download

COPY . .

ARG VERSION=dev
ARG GIT_COMMIT=unknown
ARG BUILD_DATE=unknown

RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build \
    -ldflags="-s -w \
      -X github.com/faroshq/faros-kedge/pkg/version.Version=${VERSION} \
      -X github.com/faroshq/faros-kedge/pkg/version.GitCommit=${GIT_COMMIT} \
      -X github.com/faroshq/faros-kedge/pkg/version.BuildDate=${BUILD_DATE}" \
    -o /kedge ./cmd/kedge/

FROM alpine:3.21
RUN apk add --no-cache ca-certificates
COPY --from=builder /kedge /kedge
USER 65534:65534
ENTRYPOINT ["/kedge", "agent", "run"]
