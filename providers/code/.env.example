# Local-dev environment for the kedge "code" provider.
#
# Copy to providers/code/.env and fill in the values. `make run-provider-code`
# (and therefore `tilt up`, which calls it) auto-sources providers/code/.env, so
# no manual `export` is needed. The file is gitignored.
#
# Everything here is OPT-IN: with no .env the provider runs fine and the portal
# shows only the manual "Add token manually" (PAT) form. Set the two GitHub
# OAuth values below to enable the one-click "Connect with GitHub" popup.
#
# ── Enable "Connect with GitHub" ────────────────────────────────────────────
# 1. Register a GitHub OAuth App: https://github.com/settings/developers → "New
#    OAuth App". Set:
#       Homepage URL:               https://localhost:9443
#       Authorization callback URL: http://localhost:8083/oauth/github/callback
#    (the callback MUST exactly match GITHUB_OAUTH_REDIRECT_URL below)
# 2. Put the generated Client ID + a generated Client Secret here.
# 3. tilt up  (or: make run-provider-code)
#
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ── Defaults (override only if hub/provider run on different hosts) ──────────
# Provider's own externally-reachable callback (the browser hits this directly,
# bypassing the hub's auth). Must match the GitHub OAuth App's callback URL.
GITHUB_OAUTH_REDIRECT_URL=http://localhost:8083/oauth/github/callback

# The hub/portal origin the popup postMessages the token back to. The portal is
# served from the hub, so this is the hub's external URL.
GITHUB_OAUTH_PORTAL_ORIGIN=https://localhost:9443

# Requested token scopes: repo lifecycle + deploy keys + org read +
# package read (for the repo Packages panel). Uncomment to override the default.
# GITHUB_OAUTH_SCOPES=repo,read:org,admin:public_key,read:packages
